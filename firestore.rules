rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles of the sweepstakes users (students and admins)
    match /users/{userId} {
      allow read, write: if true;
    }

    // World Cup match fixtures database
    match /matches/{matchId} {
      allow read, write: if true;
    }

    // Bets cast by students on different match indices
    match /bets/{betId} {
      allow read, write: if true;
    }
  }
}
